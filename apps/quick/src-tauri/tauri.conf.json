{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IrisNotes Quick",
  "identifier": "com.irisnotes.quick",
  "version": "1.0.5",
  "build": {
    "beforeDevCommand": "pnpm run dev:frontend",
    "devUrl": "http://localhost:3333",
    "beforeBuildCommand": "pnpm run build:frontend",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "IrisNotes Quick Search",
        "label": "main",
        "width": 1100,
        "height": 450,
        "minWidth": 400,
        "minHeight": 200,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
